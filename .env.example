# ─────────────────────────────────────────────────────────────────────────────
# jotform-faxage-bridge — configuration
# Copy to ".env" and fill in real values.  NEVER commit the real .env.
# In production, prefer sourcing the three secrets (JOTFORM_API_KEY, FAXAGE_PASSWORD,
# SHARED_SECRET) from AWS Secrets Manager/SSM via an IAM instance role rather than .env.
# ─────────────────────────────────────────────────────────────────────────────

# --- Service ---
PORT=3000                              # local/container port (kept behind the reverse proxy)
PUBLIC_DOMAIN=fax-bridge.example.com   # the public hostname Jotform will POST to (informational)
WEBHOOK_PATH=/jotform-fax              # the route Jotform's webhook targets
SHARED_SECRET=                         # REQUIRED, >=32 chars high-entropy: `openssl rand -hex 32`
WEBHOOK_TOKEN_HEADER=x-webhook-token   # preferred way Jotform sends the token (a custom header)
LOG_LEVEL=info                         # error | warn | info | debug  (PHI is NEVER logged)
DATA_DIR=./data                        # persistent dir for dedup claims + disclosure log (mount a volume; /data in container)
TRUST_PROXY=1                          # number of proxy hops in front (Caddy = 1)
RATE_LIMIT_PER_MIN=60                  # max webhook requests per IP per minute
MAX_PDF_MB=30                          # cap on a fetched PDF (memory-exhaustion guard)

# --- Jotform ---
JOTFORM_API_KEY=                       # Full-Access API key for the Jotform account (HIPAA account in prod)
JOTFORM_API_BASE=https://hipaa-api.jotform.com   # HIPAA host (https only); api.jotform.com for a non-HIPAA/dev account
JOTFORM_PDF_MODE=generatePDF           # retrieval path: generatePDF (confirmed) | getSubmissionPDF

# --- Faxage ---
FAX_DEST=18775400750                   # default destination fax (10/11 digits)
FAXAGE_USERNAME=                       # Faxage account username  (reuse the existing MOF Faxage creds)
FAXAGE_COMPANY=                        # Faxage company id
FAXAGE_PASSWORD=                       # Faxage password
FAXAGE_CALLERID=                       # caller id shown on the outbound fax (optional)
FAXAGE_URL=https://api.faxage.com/httpsfax.php   # https only

# --- Optional per-form routing override ---
# JSON object mapping a Jotform formID to a destination fax number (10/11 digits).
# Empty ("{}") => every form goes to FAX_DEST. Populate to route specific forms elsewhere.
# Example: {"251234567890123":"19185551234"}
FORM_FAX_MAP={}
