# ─────────────────────────────────────────────────────────────────────────────
# mof-jotform-faxage-bridge — configuration
# Copy to ".env" and fill in real values.  NEVER commit the real .env.
# Everything deployment-specific lives here; nothing is hardcoded in the program,
# so the same image can power any Jotform -> Faxage bridge by changing this file.
# ─────────────────────────────────────────────────────────────────────────────

# --- Service ---
PORT=3000                              # local/container port (kept behind the reverse proxy)
PUBLIC_DOMAIN=fax-bridge.example.com   # the public hostname Jotform will POST to (informational)
WEBHOOK_PATH=/jotform-fax              # the route Jotform's webhook targets
SHARED_SECRET=change-me-to-a-long-random-string   # gate for inbound webhooks (?token=...)
LOG_LEVEL=info                         # error | warn | info | debug  (PHI is NEVER logged)

# --- Jotform ---
JOTFORM_API_KEY=                       # API key for the Jotform account (HIPAA account in prod)
JOTFORM_API_BASE=https://hipaa-api.jotform.com   # HIPAA host; use https://api.jotform.com for a non-HIPAA/dev account
JOTFORM_PDF_MODE=getSubmissionPDF      # which retrieval path to use: getSubmissionPDF | generatePDF | uploadFile
                                       #   (Phase 0 probe decides which one is correct for your account)

# --- Faxage ---
FAX_DEST=18775400750                   # default destination fax number (digits only)
FAXAGE_USERNAME=                       # Faxage account username  (reuse the existing MOF Faxage creds)
FAXAGE_COMPANY=                        # Faxage company id
FAXAGE_PASSWORD=                       # Faxage password
FAXAGE_CALLERID=                       # caller id shown on the outbound fax (optional)
FAXAGE_URL=https://api.faxage.com/httpsfax.php

# --- Optional per-form routing override ---
# JSON object mapping a Jotform formID to a destination fax number.
# Empty ("{}") => every form goes to FAX_DEST. Populate to route specific forms elsewhere.
# Example: {"251234567890123":"19185551234","250000000000000":"14155550000"}
FORM_FAX_MAP={}
